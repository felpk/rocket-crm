generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("client") // "admin" | "client"
  phone         String?
  company       String?
  avatar        String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  leads         Lead[]
  automations   Automation[]
  whatsappConnection WhatsappConnection?
  googleAdsConnection GoogleAdsConnection?
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  value       Float    @default(0)
  origin      String?
  notes       String?
  stage         String    @default("lead") // lead, qualification, meeting, proposal, negotiation, closed
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages       Message[]
  automationLogs AutomationLog[]
}

model Automation {
  id          String   @id @default(cuid())
  name        String
  triggerType String   // entry, followup, stage_change, keyword
  triggerConfig String // JSON config
  actionType  String   @default("chain") // legacy compat
  actionConfig String  @default("{}") // legacy compat
  actions     String   @default("[]") // JSON array of { type, config }
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  logs        AutomationLog[]
}

model AutomationLog {
  id           String   @id @default(cuid())
  status       String   // success, error, skipped
  details      String?
  executedAt   DateTime @default(now())

  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  leadId       String?
  lead         Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model WhatsappConnection {
  id           String   @id @default(cuid())
  instanceName String
  status       String   @default("disconnected") // connected, disconnected
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoogleAdsConnection {
  id              String   @id @default(cuid())
  customerId      String
  loginCustomerId String?  // MCC ID when accessing through a manager account
  accessToken     String
  refreshToken    String
  tokenExpiry     DateTime
  accountName     String?
  managedAccounts String?  // JSON: [{ id, name }] — cached MCC client accounts
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  content   String
  fromMe    Boolean  @default(false)
  timestamp DateTime @default(now())

  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
